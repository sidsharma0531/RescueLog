# =============================================================
# RescueLog — environment variables
# -------------------------------------------------------------
# Copy the WEB block into  web/.env.local
# Set API_BASE_URL inside  mobile/src/constants/config.js
# Never commit real keys — .env.local is gitignored.
# =============================================================

# --- WEB (web/.env.local) -----------------------------------

# Supabase project — Settings > API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Anthropic — console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Vision model used for food categorization. Override to pin a snapshot.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Admin dashboard session signing secret — generate any long random string,
# e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# --- MOBILE (mobile/src/constants/config.js) ----------------
# Not loaded from this file — copy the value into config.js manually.
# Use your Vercel deployment URL in production, or your machine's LAN IP
# (e.g. http://192.168.1.20:3000) when testing against a local web server.
API_BASE_URL=https://your-app.vercel.app
